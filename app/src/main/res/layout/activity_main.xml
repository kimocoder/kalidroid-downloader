<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Main card panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/main_panel_bg"
        android:orientation="vertical"
        android:clipToPadding="false">

            <!-- Header strip with version chip + ready indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/main_header_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/phase_chip_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:id="@+id/ivPhaseIcon"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_package"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvPhase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/kali_blue"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.18"
                        android:text="@string/main_chip_version" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <View
                    android:id="@+id/mainStatusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvLive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/valid_green"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.18"
                    android:text="@string/main_ready_label" />
            </LinearLayout>

            <!-- ======================================================== -->
            <!-- IDLE PANEL : logo + app name + download button           -->
            <!-- ======================================================== -->
            <LinearLayout
                android:id="@+id/idlePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="36dp"
                android:paddingBottom="20dp">

                <ImageView
                    android:id="@+id/ivMainRingScanner"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ring_scanner"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/ivMainRingDashed"
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ring_dashed"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center"
                    android:src="@drawable/kalilinux"
                    android:contentDescription="@string/logo_desc" />
            </FrameLayout>

            <!-- App name -->
            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/app_name"
                android:textSize="40sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:shadowColor="@color/kali_blue"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="22" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="2dp"
                android:text="@string/subtitle"
                android:textSize="11sp"
                android:textColor="@color/kali_blue"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:textAllCaps="true"
                android:textStyle="bold" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:text="@string/main_tagline"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06" />

            <!-- Divider before action -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#21262D" />

            <!-- Download button styled like the gradient bar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownload"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="@string/btn_download"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.16"
                android:fontFamily="monospace"
                android:textColor="@color/bg_dark"
                app:icon="@drawable/ic_download"
                app:iconTint="@color/bg_dark"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:cornerRadius="8dp"
                app:backgroundTint="@null"
                android:background="@drawable/btn_gradient" />

            <!-- Footer line -->
            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="@string/main_footer"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.28" />

            </LinearLayout>

        <!-- ============================================================ -->
        <!-- PROGRESS PANEL : shown while downloading / installing        -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/progressPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Big circular progress with decorative rings -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="28dp"
                android:paddingBottom="20dp">

                <ImageView
                    android:id="@+id/ivRingScanner"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ring_scanner"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/ivRingDashed"
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ring_dashed"
                    android:contentDescription="@null" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/circularProgress"
                    android:layout_width="148dp"
                    android:layout_height="148dp"
                    android:layout_gravity="center"
                    android:indeterminate="false"
                    app:indicatorColor="@color/kali_blue"
                    app:trackColor="#1A58A6FF"
                    app:trackThickness="8dp"
                    app:indicatorSize="148dp"
                    app:trackCornerRadius="8dp"
                    android:progress="0" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="-0.02"
                        android:text="0%"
                        android:shadowColor="@color/kali_blue"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="18" />

                    <TextView
                        android:id="@+id/tvPercentSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.22"
                        android:text="@string/complete_label" />
                </LinearLayout>
            </FrameLayout>

            <!-- Status line -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/status_connecting" />

            <TextView
                android:id="@+id/tvStatusHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:layout_marginTop="4dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:text="@string/status_hint_connect" />

            <!-- Linear gradient progress bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_gradient" />

            <!-- Stats grid: speed / size / eta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp"
                android:baselineAligned="false">

                <!-- Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/stat_tile_bg"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginEnd="6dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:src="@drawable/ic_speed"
                            android:layout_marginEnd="5dp"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.18"
                            android:text="@string/label_speed" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:text="@string/dash" />
                </LinearLayout>

                <!-- Downloaded / Total -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/stat_tile_bg"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:src="@drawable/ic_package"
                            android:layout_marginEnd="5dp"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.18"
                            android:text="@string/label_size" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:text="@string/dash" />
                </LinearLayout>

                <!-- ETA -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/stat_tile_bg"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="6dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:src="@drawable/ic_clock"
                            android:layout_marginEnd="5dp"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.18"
                            android:text="@string/label_eta" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:text="@string/dash" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider before the action area -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#21262D" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="@android:string/cancel"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:textAllCaps="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
